# Copy to .env at repo root and edit. docker-compose picks this up via ${VAR:-} interpolation.

# --- Database ---
# In docker: backend talks to postgres service via internal hostname `postgres`.
# Outside docker (local uvicorn): use localhost.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fintech

# --- Embeddings ---
# Leave GOOGLE_API_KEY empty to use the deterministic mock embedding fallback.
# When set, the EmbeddingClient switches to Gemini automatically.
GOOGLE_API_KEY=
EMBEDDING_MODEL=gemini-embedding-2
EMBEDDING_DIM=768

# --- FAISS persistence ---
FAISS_DIR=./storage/faiss

# --- Database hygiene ---
# Set to 1 to drop and recreate every table on next startup, then reseed.
RESET_DB=0

# --- CORS ---
# Comma-separated list of allowed origins. 8080 is the Lovable Vite dev port.
CORS_ORIGINS=http://localhost:8080,http://localhost:3000
